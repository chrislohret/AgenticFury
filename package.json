{
  "name": "power-apps-template-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port 3000\" \"pac code run\"",
    "build": "npm run typecheck && vite build",
    "lint": "eslint src/ --max-warnings 0",
    "preview": "vite preview",
    "dev:local": "set VITE_USE_MOCK=true && vite --port 3000",
    "prototype:seed": "pacaf-seed dataverse/planning-payload.json",
    "typecheck": "tsc --noEmit",
    "prebuild": "pacaf-patch-datasources",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run --reporter=verbose src/App.test.tsx",
    "test:e2e": "playwright test",
    "setup:auth": "pacaf-setup-auth",
    "pac": "pacaf-pac",
    "solution:export": "pacaf-export-solution --name YourSolutionName --target dev",
    "solution:export:unmanaged": "pacaf-export-solution --name YourSolutionName --target dev --unmanaged-only",
    "deploy": "npm run build && pacaf-pac-safe --target dev --profile-type spn --mutating code push",
    "validate:schema-plan": "pacaf-validate dataverse/planning-payload.json",
    "generate:dataverse-plan": "pacaf-generate dataverse/planning-payload.json",
    "register:dataverse": "pacaf-register dataverse/register-datasources.plan.json",
    "sync:foundations": "pacaf-update",
    "sync:foundations:check": "pacaf-update --check"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.8",
    "@microsoft/power-apps": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.546.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.11.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@microsoft/power-apps-vite": "^1.0.2",
    "@pacaf/agent-instructions": "^3.4.0",
    "@pacaf/scripts": "^3.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^25.0.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
